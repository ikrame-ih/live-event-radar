# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# test / tooling artifacts
/test-results/

# editor / IDE
.cursor/

# Nested copy (mistake folder—do not publish)
/live-event-radar/

# Flowbite CLI cache (plugin regenerates via prebuild/predev script)
.flowbite-react/class-list.json
.flowbite-react/pid
